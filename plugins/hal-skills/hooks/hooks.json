{
  "description": "Deny Bash commands from the committer subagent that could modify the working tree or fabricate staged content",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-committer-bash.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
