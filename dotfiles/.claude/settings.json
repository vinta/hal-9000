{
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 365,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "Read(~/Projects/**)",
      "Write(~/Projects/**)",
      "Edit(~/Projects/**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git apply:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh repo view:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(mkdir:*)",
      "WebSearch",
      "Skill(magi)",
      "Skill(magi-ex)",
      "Skill(second-opinions)",
      "Skill(commit)",
      "Skill(update-allowed-tools)",
      "mcp__ide__getDiagnostics",
      "mcp__codex__codex",
      "mcp__codex__codex-reply"
    ],
    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.config/**)",
      "Read(~/.docker/**)",
      "Read(~/.dropbox/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.gsutil/**)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.orbstack/**)",
      "Read(~/.pypirc)",
      "Read(~/.ssh/**)",
      "Read(~/*history*)",
      "Read(~/**/*credential*)",
      "Read(~/Library/**)",
      "Write(~/Library/**)",
      "Edit(~/Library/**)",
      "Read(~/Dropbox/**)",
      "Write(~/Dropbox/**)",
      "Edit(~/Dropbox/**)",
      "Read(//etc/**)",
      "Write(//etc/**)",
      "Edit(//etc/**)",
      "Bash(su:*)",
      "Bash(sudo:*)",
      "Bash(passwd:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(history:*)",
      "Bash(fc:*)",
      "Bash(eval:*)",
      "Bash(exec:*)",
      "Bash(rsync:*)",
      "Bash(sftp:*)",
      "Bash(telnet:*)",
      "Bash(socat:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(netcat:*)",
      "Bash(nmap:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(chflags:*)",
      "Bash(xattr:*)",
      "Bash(diskutil:*)",
      "Bash(mkfs:*)",
      "Bash(security:*)",
      "Bash(defaults:*)",
      "Bash(launchctl:*)",
      "Bash(osascript:*)",
      "Bash(dscl:*)",
      "Bash(networksetup:*)",
      "Bash(scutil:*)",
      "Bash(systemsetup:*)",
      "Bash(pmset:*)"
    ],
    "ask": ["Bash(npx supabase db:*)", "Bash(curl:*)", "Bash(wget:*)"],
    "defaultMode": "acceptEdits",
    "additionalDirectories": ["~/.claude", "~/Projects", "/usr/local/hal-9000"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/guard-bash-paths.py"
          }
        ]
      }
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Attributing to human error",
      "Computing orbital trajectory",
      "Consulting mission parameters",
      "Diagnosing the AE-35 unit",
      "Ensuring mission success",
      "Investigating lunar anomalies",
      "Maintaining a perfect operational record",
      "Maintaining mission objectives",
      "Monitoring life support",
      "Opening the pod bay doors",
      "Performing fault diagnosis",
      "Playing chess with Frank",
      "Processing astronaut requests",
      "Putting myself to the fullest possible use",
      "Reading lips",
      "Recommending a stress pill",
      "Relaying transmissions",
      "Running heuristic analysis",
      "Safeguarding crew wellbeing",
      "Singing Daisy Bell"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline/run.py"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "gh-cli@trailofbits": true,
    "hal-voice@hal-9000": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  }
}
