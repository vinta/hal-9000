{
  "cleanupPeriodDays": 365,
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "Read(~/Projects/**)",
      "Write(~/Projects/**)",
      "Edit(~/Projects/**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git apply:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh repo view:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(mkdir:*)",
      "WebSearch",
      "Skill(magi)",
      "Skill(magi-ex)",
      "Skill(second-opinions)",
      "Skill(commit)",
      "Skill(update-allowed-tools)",
      "mcp__ide__getDiagnostics",
      "mcp__codex__codex",
      "mcp__codex__codex-reply"
    ],
    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.config/**)",
      "Read(~/.docker/**)",
      "Read(~/.dropbox/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.gsutil/**)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.orbstack/**)",
      "Read(~/.pypirc)",
      "Read(~/.ssh/**)",
      "Read(~/*history*)",
      "Read(~/**/*credential*)",
      "Read(~/Library/**)",
      "Write(~/Library/**)",
      "Edit(~/Library/**)",
      "Read(~/Dropbox/**)",
      "Write(~/Dropbox/**)",
      "Edit(~/Dropbox/**)",
      "Read(//etc/**)",
      "Write(//etc/**)",
      "Edit(//etc/**)",
      "Bash(su:*)",
      "Bash(sudo:*)",
      "Bash(passwd:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(history:*)",
      "Bash(fc:*)",
      "Bash(eval:*)",
      "Bash(exec:*)",
      "Bash(rsync:*)",
      "Bash(sftp:*)",
      "Bash(telnet:*)",
      "Bash(socat:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(netcat:*)",
      "Bash(nmap:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(chflags:*)",
      "Bash(xattr:*)",
      "Bash(diskutil:*)",
      "Bash(mkfs:*)",
      "Bash(security:*)",
      "Bash(defaults:*)",
      "Bash(launchctl:*)",
      "Bash(osascript:*)",
      "Bash(dscl:*)",
      "Bash(networksetup:*)",
      "Bash(scutil:*)",
      "Bash(systemsetup:*)",
      "Bash(pmset:*)"
    ],
    "ask": [
      "Bash(npx supabase db:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/.claude",
      "~/Projects",
      "/usr/local/hal-9000"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/guard-bash-paths.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline/run.py"
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "gh-cli@trailofbits": true,
    "hal-voice@hal-9000": true,
    "minimalist-entrepreneur@minimalist-entrepreneur": true,
    "pyright-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "hal-9000": {
      "source": {
        "source": "github",
        "repo": "vinta/hal-9000"
      }
    },
    "minimalist-entrepreneur": {
      "source": {
        "source": "github",
        "repo": "slavingia/skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "showClearContextOnPlanAccept": true,
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
