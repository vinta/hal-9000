# Reference of all Ghostty configuration options
# https://ghostty.org/docs/config/reference

# https://ghostty.org/docs/config/reference#theme
# theme = Bluloco Dark
theme = Catppuccin Mocha

# https://ghostty.org/docs/config/reference#font-size
font-size = 14
adjust-cell-height = 2

# https://ghostty.org/docs/config/reference#cursor-style
cursor-style = bar
cursor-style-blink = false

# https://ghostty.org/docs/config/reference#maximize
maximize = true

# https://ghostty.org/docs/config/reference#shell-integration-features
shell-integration-features = no-cursor,title,ssh-env,ssh-terminfo

# https://ghostty.org/docs/config/reference#scrollback-limit
scrollback-limit = 50000000

# https://ghostty.org/docs/config/reference#clipboard-paste-protection
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# https://ghostty.org/docs/config/reference#quick-terminal-position
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# https://ghostty.org/docs/config/keybind/reference#new_split
# https://ghostty.org/docs/config/keybind/reference#toggle_split_zoom
keybind = cmd+alt+h=new_split:down
keybind = cmd+alt+v=new_split:right
keybind = cmd+alt+enter=toggle_split_zoom
keybind = cmd+backquote=toggle_quick_terminal
